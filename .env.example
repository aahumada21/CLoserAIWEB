# Variables del canal webchat (demo del chatbot en /demo)
# Cópialas a .env.production en la VPS con los valores reales.
# No se commitean: .gitignore ya excluye .env*

# Token compartido con el adapter de n8n (X-Webchat-Token)
WEBCHAT_WIDGET_TOKEN=

# URLs reales del backend n8n para este canal
N8N_WEBCHAT_INBOUND_URL=https://n8n.aahumada.com/webhook/webchat-inbound
N8N_WEBCHAT_OUTBOUND_URL=https://n8n.aahumada.com/webhook/webchat-outbound

# Identificador del canal (debe coincidir con agent_channels.external_channel_id)
WEBCHAT_WIDGET_ID=closer-web-demo

# Flag para activar el chat real en /demo (false hasta confirmar que el
# backend de n8n tiene el mecanismo de salida funcionando)
WEBCHAT_REAL_ENABLED=false

# Panel de login (Supabase Auth). El proyecto Supabase es el mismo que usa
# n8n para la base de datos. Sacar los valores reales del dashboard:
# https://app.supabase.com/project/<ref>/settings/api
# La anon key es publica (se expone al navegador). La service role key
# NUNCA debe ir en NEXT_PUBLIC_* ni usarse en codigo de cliente: bypasea RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Onboarding: crear agente nuevo desde el panel (server-only, nunca en el
# cliente). Mismo patron que WEBCHAT_WIDGET_TOKEN: secreto compartido solo
# entre este backend y n8n, no es un JWT de Supabase.
ONBOARDING_API_TOKEN=
N8N_ONBOARDING_URL=https://n8n.aahumada.com/webhook/onboarding-create-agent

# Conexion de Google Calendar por agente (OAuth). El Client ID es publico
# a proposito (Google lo expone igual en la URL de autorizacion), pero
# requiere que exista el OAuth Client en Google Cloud Console primero
# (ver docs/GOOGLE_CALENDAR_OAUTH_2026-06-22.md). El Client Secret NUNCA
# va aqui: vive solo en el entorno de n8n.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# Desvincular un Google Calendar conectado (revoca el token en Google y
# borra el registro guardado). Server-only, mismo patron que los anteriores.
DISCONNECT_GOOGLE_CALENDAR_TOKEN=
N8N_DISCONNECT_GOOGLE_CALENDAR_URL=https://n8n.aahumada.com/webhook/disconnect-google-calendar

